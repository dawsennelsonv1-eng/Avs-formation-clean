# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Gemini (screenshot ID extraction + AI tutor in ZIP 3)
GEMINI_API_KEY=your-gemini-key

# Payment receiver details (MonCash / NatCash) — shown to the client
NEXT_PUBLIC_MONCASH_NAME=Dawsen Nelson
NEXT_PUBLIC_MONCASH_PHONE=+509 00 00 0000
NEXT_PUBLIC_NATCASH_NAME=Dawsen Nelson
NEXT_PUBLIC_NATCASH_PHONE=+509 00 00 0000

# Shared secret for the SMS forwarder webhook (POST /api/sms/inbound)
SMS_FORWARDER_SECRET=set-a-long-random-string

# Auth: configure Site URL + Redirect URLs in Supabase Dashboard > Authentication > URL Configuration
# Add: http://localhost:3000/auth/callback  and  https://<your-domain>/auth/callback

# Public site URL (used for OG metadata + auth redirects in prod)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
